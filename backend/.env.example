# ========== 数据库配置 ==========
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=conversa

# ========== JWT 配置 ==========
JWT_SECRET=yourverysecurekey
JWT_EXPIRY=7d

# ========== AI 功能（可选）==========
GLM_API_KEY=
GLM_MODEL=glm-4.5-air
IMAGE_GEN_MODEL=cogview-3

# ========== 天气功能（可选）==========
AMAP_API_KEY=

# ========== 邮件功能（可选）==========
EMAIL=your.email@example.com
PASSWORD=your.password

# ========== CORS 配置 ==========
# 本地开发：*
# 生产环境：你的前端域名
CORS_ORIGIN=*

# ========== 前端 URL ==========
FRONTEND_URL=http://localhost:5173

# ========== 端口（Render 自动设置）==========
# PORT=10000
